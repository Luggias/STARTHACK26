# Rename to ".env" and fill in your keys — never commit this file!

# AI APIs — console.anthropic.com / platform.openai.com
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-...

# Supabase — supabase.com → project settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# Frontend URL for CORS (Vercel production URL or localhost)
FRONTEND_URL=http://localhost:3000
